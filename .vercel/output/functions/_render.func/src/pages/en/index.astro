---
import Layout from '../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { supabase } from '../../lib/supabase';

export const prerender = false;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const user = Astro.locals.user;
const firstName = user?.user_metadata?.full_name?.split(' ')[0] || user?.email?.split('@')[0] || '';

// Fetch current month data server-side
const now = new Date();
const year = now.getFullYear();
const month = now.getMonth();
const startDate = `${year}-${String(month + 1).padStart(2, '0')}-01`;
const endDate = new Date(year, month + 1, 0).toISOString().split('T')[0];

const fmt = new Intl.NumberFormat('es-AR', { style: 'currency', currency: 'ARS' });

// Transactions this month
const { data: transactions } = await supabase
  .from('transactions')
  .select('type, amount, date, notes, categories(name, icon)')
  .gte('date', startDate)
  .lte('date', endDate)
  .order('date', { ascending: false });

const txs = transactions || [];
const income = txs.filter((t: any) => t.type === 'income').reduce((s: number, t: any) => s + t.amount, 0);
const expenses = txs.filter((t: any) => t.type === 'expense').reduce((s: number, t: any) => s + t.amount, 0);
const balance = income - expenses;

// Savings
const { data: goals } = await supabase.from('savings_goals').select('current_amount');
const totalSaved = (goals || []).reduce((s: number, g: any) => s + (g.current_amount || 0), 0);

// Categories for QuickAdd
const { data: categories } = await supabase.from('categories').select('id, name, icon').order('name');
const cats = categories || [];

// Recent 5
const recent = txs.slice(0, 5);
---

<Layout title={`${t('dash.title')} — FinApp`}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Welcome -->
    <div class="mb-8 reveal">
      <h1 class="text-2xl sm:text-3xl font-bold text-slate-100">
        {t('dash.welcome')}, <span class="bg-gradient-to-r from-emerald-400 to-cyan-400 bg-clip-text text-transparent">{firstName}</span> 👋
      </h1>
      <p class="text-slate-400 mt-1">{t('dash.thisMonth')}</p>
    </div>

    <!-- Bento Grid Summary Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
      <!-- Income -->
      <div class="glass rounded-2xl p-5 reveal hover:border-emerald-500/30 transition-all duration-300" style="--reveal-delay: 100ms">
        <div class="flex items-center justify-between mb-3">
          <div class="w-10 h-10 rounded-xl bg-emerald-500/10 flex items-center justify-center">
            <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 11l5-5m0 0l5 5m-5-5v12"></path></svg>
          </div>
        </div>
        <p class="text-sm text-slate-400 mb-1">{t('dash.income')}</p>
        <p class="text-2xl font-bold text-slate-100">{fmt.format(income)}</p>
      </div>

      <!-- Expenses -->
      <div class="glass rounded-2xl p-5 reveal hover:border-rose-500/30 transition-all duration-300" style="--reveal-delay: 200ms">
        <div class="flex items-center justify-between mb-3">
          <div class="w-10 h-10 rounded-xl bg-rose-500/10 flex items-center justify-center">
            <svg class="w-5 h-5 text-rose-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 13l-5 5m0 0l-5-5m5 5V6"></path></svg>
          </div>
        </div>
        <p class="text-sm text-slate-400 mb-1">{t('dash.expenses')}</p>
        <p class="text-2xl font-bold text-slate-100">{fmt.format(expenses)}</p>
      </div>

      <!-- Balance -->
      <div class="glass rounded-2xl p-5 reveal hover:border-cyan-500/30 transition-all duration-300" style="--reveal-delay: 300ms">
        <div class="flex items-center justify-between mb-3">
          <div class="w-10 h-10 rounded-xl bg-cyan-500/10 flex items-center justify-center">
            <svg class="w-5 h-5 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          </div>
        </div>
        <p class="text-sm text-slate-400 mb-1">{t('dash.balance')}</p>
        <p class={`text-2xl font-bold ${balance >= 0 ? 'text-emerald-400' : 'text-rose-400'}`}>{fmt.format(balance)}</p>
      </div>

      <!-- Savings -->
      <div class="glass rounded-2xl p-5 reveal hover:border-amber-500/30 transition-all duration-300" style="--reveal-delay: 400ms">
        <div class="flex items-center justify-between mb-3">
          <div class="w-10 h-10 rounded-xl bg-amber-500/10 flex items-center justify-center">
            <svg class="w-5 h-5 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"></path></svg>
          </div>
        </div>
        <p class="text-sm text-slate-400 mb-1">{t('dash.savings')}</p>
        <p class="text-2xl font-bold text-slate-100">{fmt.format(totalSaved)}</p>
      </div>
    </div>

    <!-- Charts Section (Bento Grid) -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 mb-8 content-auto">
      <div class="lg:col-span-2 glass rounded-2xl p-6 reveal" style="--reveal-delay: 500ms">
        <h2 class="text-lg font-semibold text-slate-200 mb-4">{t('chart.comparison')}</h2>
        <div class="relative" style="height: 300px;"><canvas id="comparison-chart"></canvas></div>
      </div>
      <div class="glass rounded-2xl p-6 reveal" style="--reveal-delay: 600ms">
        <h2 class="text-lg font-semibold text-slate-200 mb-4">{t('chart.breakdown')}</h2>
        <div class="relative" style="height: 300px;"><canvas id="breakdown-chart"></canvas></div>
      </div>
    </div>

    <!-- Trend -->
    <div class="glass rounded-2xl p-6 mb-8 reveal content-auto" style="--reveal-delay: 700ms">
      <h2 class="text-lg font-semibold text-slate-200 mb-4">{t('chart.trend')}</h2>
      <div class="relative" style="height: 250px;"><canvas id="trend-chart"></canvas></div>
    </div>

    <!-- Recent Transactions -->
    <div class="glass rounded-2xl p-6 reveal" style="--reveal-delay: 800ms">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold text-slate-200">{t('tx.title')}</h2>
        <a href={`/${lang}/transactions`} class="text-sm text-emerald-400 hover:text-emerald-300 transition-colors">{t('tx.all')} →</a>
      </div>
      <div class="space-y-2">
        {recent.length === 0 && (
          <p class="text-slate-500 text-sm text-center py-8">{t('dash.noData')}</p>
        )}
        {recent.map((tx: any) => (
          <div class="flex items-center justify-between py-3 border-b border-slate-800/50 last:border-0">
            <div class="flex items-center gap-3">
              <span class="text-lg">{(tx.categories as any)?.icon || '📁'}</span>
              <div>
                <p class="text-sm font-medium text-slate-200">{(tx.categories as any)?.name || ''}</p>
                <p class="text-xs text-slate-500">{tx.notes || tx.date}</p>
              </div>
            </div>
            <span class={`font-semibold ${tx.type === 'income' ? 'text-emerald-400' : 'text-rose-400'}`}>
              {tx.type === 'income' ? '+' : '-'}{fmt.format(tx.amount)}
            </span>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Quick Add FAB -->
  <button
    id="quick-add-btn"
    class="fixed bottom-6 right-6 w-14 h-14 rounded-2xl bg-gradient-to-br from-emerald-500 to-cyan-500 text-white shadow-lg shadow-emerald-500/25 hover:shadow-emerald-500/40 hover:scale-105 transition-all duration-300 flex items-center justify-center z-40"
    aria-label={t('tx.add')}
  >
    <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"></path>
    </svg>
  </button>

  <!-- Quick Add Modal -->
  <div id="quick-add-modal" class="fixed inset-0 z-50 hidden">
    <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" id="modal-backdrop"></div>
    <div class="absolute bottom-0 left-0 right-0 sm:bottom-auto sm:top-1/2 sm:left-1/2 sm:-translate-x-1/2 sm:-translate-y-1/2 sm:max-w-lg sm:w-full">
      <div class="glass rounded-t-2xl sm:rounded-2xl p-6 animate-slide-up">
        <div class="flex items-center justify-between mb-6">
          <h3 class="text-lg font-semibold text-slate-200">{t('tx.add')}</h3>
          <button id="modal-close" class="p-1 rounded-lg hover:bg-slate-700/50 text-slate-400">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
          </button>
        </div>

        <form id="quick-add-form" method="post" action="/api/transactions" class="space-y-4">
          <div class="grid grid-cols-2 gap-2">
            <button type="button" data-type="expense" class="type-btn active px-4 py-2.5 rounded-xl text-sm font-medium bg-rose-500/20 text-rose-400 border border-rose-500/30">{t('tx.expense')}</button>
            <button type="button" data-type="income" class="type-btn px-4 py-2.5 rounded-xl text-sm font-medium bg-white/5 text-slate-400 border border-slate-700/50">{t('tx.income')}</button>
          </div>
          <input type="hidden" name="type" value="expense" id="tx-type" />

          <div>
            <label class="text-sm text-slate-400 mb-1 block">{t('tx.amount')}</label>
            <input type="number" name="amount" id="tx-amount" step="0.01" min="0" required placeholder="0.00" class="w-full px-4 py-3 rounded-xl bg-white/5 border border-slate-700/50 text-slate-100 text-lg font-semibold placeholder-slate-600 focus:border-emerald-500/50 focus:ring-1 focus:ring-emerald-500/25 outline-none transition-all" />
          </div>

          <div>
            <label class="text-sm text-slate-400 mb-1 block">{t('tx.category')}</label>
            <select name="category_id" class="w-full px-4 py-2.5 rounded-xl bg-white/5 border border-slate-700/50 text-slate-100 focus:border-emerald-500/50 outline-none appearance-none">
              <option value="">...</option>
              {cats.map((c: any) => (
                <option value={c.id}>{c.icon} {c.name}</option>
              ))}
            </select>
          </div>

          <div>
            <label class="text-sm text-slate-400 mb-1 block">{t('tx.method')}</label>
            <div class="grid grid-cols-4 gap-2">
              <button type="button" data-method="cash" class="method-btn active px-3 py-2 rounded-lg text-xs font-medium bg-emerald-500/20 text-emerald-400 border border-emerald-500/30">{t('tx.cash')}</button>
              <button type="button" data-method="debit" class="method-btn px-3 py-2 rounded-lg text-xs font-medium bg-white/5 text-slate-400 border border-slate-700/50">{t('tx.debit')}</button>
              <button type="button" data-method="credit" class="method-btn px-3 py-2 rounded-lg text-xs font-medium bg-white/5 text-slate-400 border border-slate-700/50">{t('tx.credit')}</button>
              <button type="button" data-method="transfer" class="method-btn px-3 py-2 rounded-lg text-xs font-medium bg-white/5 text-slate-400 border border-slate-700/50">{t('tx.transfer')}</button>
            </div>
          </div>
          <input type="hidden" name="method" value="cash" id="tx-method" />

          <div>
            <label class="text-sm text-slate-400 mb-1 block">{t('tx.date')}</label>
            <input type="date" name="date" id="tx-date" class="w-full px-4 py-2.5 rounded-xl bg-white/5 border border-slate-700/50 text-slate-100 focus:border-emerald-500/50 outline-none" />
          </div>

          <div>
            <label class="text-sm text-slate-400 mb-1 block">{t('tx.notes')}</label>
            <input type="text" name="notes" maxlength="500" placeholder="..." class="w-full px-4 py-2.5 rounded-xl bg-white/5 border border-slate-700/50 text-slate-100 placeholder-slate-600 focus:border-emerald-500/50 outline-none" />
          </div>

          <button type="submit" class="w-full py-3 rounded-xl bg-gradient-to-r from-emerald-500 to-cyan-500 text-white font-semibold hover:shadow-lg hover:shadow-emerald-500/25 transition-all">{t('tx.save')}</button>
          <p class="text-xs text-slate-500 text-center">Ctrl + Enter</p>
        </form>
      </div>
    </div>
  </div>
</Layout>

<script>
  // Modal and toggle logic only (no Supabase client-side)
  const fab = document.getElementById('quick-add-btn');
  const modal = document.getElementById('quick-add-modal');
  const backdrop = document.getElementById('modal-backdrop');
  const closeBtn = document.getElementById('modal-close');
  const amountInput = document.getElementById('tx-amount') as HTMLInputElement;
  const dateInput = document.getElementById('tx-date') as HTMLInputElement;
  const typeInput = document.getElementById('tx-type') as HTMLInputElement;
  const methodInput = document.getElementById('tx-method') as HTMLInputElement;
  const form = document.getElementById('quick-add-form') as HTMLFormElement;

  const today = new Date().toISOString().split('T')[0];
  if (dateInput) dateInput.value = today;

  function openModal() { modal?.classList.remove('hidden'); setTimeout(() => amountInput?.focus(), 100); }
  function closeModal() { modal?.classList.add('hidden'); form?.reset(); if (dateInput) dateInput.value = today; }

  fab?.addEventListener('click', openModal);
  backdrop?.addEventListener('click', closeModal);
  closeBtn?.addEventListener('click', closeModal);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });
  document.addEventListener('keydown', (e) => { if ((e.metaKey || e.ctrlKey) && e.key === 'Enter' && !modal?.classList.contains('hidden')) form?.requestSubmit(); });

  // Type toggle
  document.querySelectorAll('.type-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.type-btn').forEach(b => { b.classList.remove('active','bg-rose-500/20','text-rose-400','border-rose-500/30','bg-emerald-500/20','text-emerald-400','border-emerald-500/30'); b.classList.add('bg-white/5','text-slate-400','border-slate-700/50'); });
      const type = (btn as HTMLElement).dataset.type;
      btn.classList.add('active'); btn.classList.remove('bg-white/5','text-slate-400','border-slate-700/50');
      if (type === 'expense') btn.classList.add('bg-rose-500/20','text-rose-400','border-rose-500/30');
      else btn.classList.add('bg-emerald-500/20','text-emerald-400','border-emerald-500/30');
      if (typeInput) typeInput.value = type || 'expense';
    });
  });

  // Method toggle
  document.querySelectorAll('.method-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.method-btn').forEach(b => { b.classList.remove('active','bg-emerald-500/20','text-emerald-400','border-emerald-500/30'); b.classList.add('bg-white/5','text-slate-400','border-slate-700/50'); });
      btn.classList.add('active','bg-emerald-500/20','text-emerald-400','border-emerald-500/30'); btn.classList.remove('bg-white/5','text-slate-400','border-slate-700/50');
      if (methodInput) methodInput.value = (btn as HTMLElement).dataset.method || 'cash';
    });
  });
</script>
