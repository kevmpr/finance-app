{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/auth/callback/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/auth/signin/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/auth/signout/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/transactions/?$",
			"dest": "_render"
		},
		{
			"src": "^/en/data/?$",
			"dest": "_render"
		},
		{
			"src": "^/en/login/?$",
			"dest": "_render"
		},
		{
			"src": "^/en/savings/?$",
			"dest": "_render"
		},
		{
			"src": "^/en/transactions/?$",
			"dest": "_render"
		},
		{
			"src": "^/en/?$",
			"dest": "_render"
		},
		{
			"src": "^/es/data/?$",
			"dest": "_render"
		},
		{
			"src": "^/es/login/?$",
			"dest": "_render"
		},
		{
			"src": "^/es/savings/?$",
			"dest": "_render"
		},
		{
			"src": "^/es/transactions/?$",
			"dest": "_render"
		},
		{
			"src": "^/es/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		}
	]
}