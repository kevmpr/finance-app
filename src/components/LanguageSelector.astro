---
import { getLangFromUrl, languages } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const currentPath = Astro.url.pathname;
---

<div class="relative" id="lang-selector">
  <button
    id="lang-toggle"
    class="p-2 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-700/50 transition-colors text-sm font-medium text-slate-600 dark:text-slate-300 flex items-center gap-1"
    aria-label="Change language"
  >
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
    </svg>
    {lang.toUpperCase()}
  </button>
  <div
    id="lang-dropdown"
    class="absolute right-0 top-full mt-1 py-1 rounded-lg glass shadow-xl min-w-[100px] opacity-0 invisible transition-all duration-200 translate-y-1"
  >
    {Object.entries(languages).map(([code, label]) => (
      <a
        href={currentPath.replace(`/${lang}/`, `/${code}/`).replace(`/${lang}`, `/${code}`)}
        class={`block px-3 py-1.5 text-sm transition-colors ${code === lang
          ? 'text-emerald-600 dark:text-emerald-400 bg-emerald-50 dark:bg-emerald-900/20'
          : 'text-slate-600 dark:text-slate-300 hover:text-emerald-600 dark:hover:text-emerald-400 hover:bg-slate-100 dark:hover:bg-slate-700/50'
        }`}
      >
        {label}
      </a>
    ))}
  </div>
</div>

<script>
  const toggle = document.getElementById('lang-toggle');
  const dropdown = document.getElementById('lang-dropdown');

  toggle?.addEventListener('click', (e) => {
    e.stopPropagation();
    dropdown?.classList.toggle('opacity-0');
    dropdown?.classList.toggle('invisible');
    dropdown?.classList.toggle('translate-y-1');
  });

  document.addEventListener('click', () => {
    dropdown?.classList.add('opacity-0', 'invisible', 'translate-y-1');
  });
</script>
